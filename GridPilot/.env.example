# ==============================================================================
# GridPilot Environment Configuration (Development)
# ==============================================================================

# PostgreSQL Configuration
POSTGRES_DB=gridpilot
POSTGRES_USER=gridpilot_app
POSTGRES_PASSWORD=postgres_dev_password_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ==============================================================================
# Alibaba Cloud Configurations (Milestone 2)
# ==============================================================================

# Object Storage Service (OSS) Config
OSS_BUCKET_NAME=your_oss_bucket_name
OSS_ACCESS_KEY_ID=your_ram_access_key_id
OSS_ACCESS_KEY_SECRET=your_ram_access_key_secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com # default endpoint, change according to region

# DashScope (Model Studio) Config
DASHSCOPE_API_KEY=your_dashscope_api_key

# ECS Server Config (for deployment target)
ECS_HOST=your_ecs_public_ip
ECS_SSH_USER=root
ECS_SSH_KEY_PATH=~/.ssh/id_rsa # Path to private SSH key for ECS access
